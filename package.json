{
  "name": "webtoken-rs",
  "version": "1.0.0",
  "description": "Web Token encoded in Rust and available as NAPI addon",
  "keywords": [
    "napi",
    "node-addon",
    "native",
    "rust",
    "bun",
    "template",
    "starter"
  ],
  "homepage": "https://github.com/nglmercer/webtoken-rs#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nglmercer/webtoken-rs.git"
  },
  "bugs": {
    "url": "https://github.com/nglmercer/webtoken-rs/issues"
  },
  "license": "MIT",
  "author": {
    "name": "nglmercer",
    "email": "nglmercer@gmail.com"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "*.node",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "clean": "napi clean && cargo clean",
    "test": "bun test",
    "bench": "bun run ./tests/benchmark.ts",
    "dev": "bun run --watch examples/dev.ts",
    "type-check": "tsc --noEmit",
    "format": "bun run --filter ./examples --filter ./scripts format",
    "lint": "rustup run stable cargo clippy -- -D warnings",
    "build:all": "bun run scripts/build_multiplatform.ts",
    "download-assets": "bun run scripts/download-release-assets.ts",
    "download-assets:help": "bun run scripts/download-release-assets.ts -- --help"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.5.1",
    "@types/bun": "^1.1.12",
    "mitata": "^1.0.34",
    "typescript": "^5.6.2"
  },
  "peerDependencies": {
    "bun": ">=1.0.0"
  },
  "napi": {
    "binaryName": "webtoken",
    "targets": [
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "dependencies": {
    "commander": "^14.0.3"
  }
}